{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "AarhusSpaceProgram.Api",
    "Audience": "AarhusSpaceProgram.Api",
    "AccessTokenMinutes": 60,
    "Key": ""
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "MissionLogsDb",
    "CollectionName": "MissionLogs"
  },
  "Serilog": {
    "MongoDbCollection": "request_logs",
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
