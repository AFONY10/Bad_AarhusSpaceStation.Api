@AarhusSpaceProgram.Api_HostAddress = http://localhost:8080
@ManagerUserName = manager@asp.local
@ManagerPassword = replace-with-your-manager-password

GET {{AarhusSpaceProgram.Api_HostAddress}}/api/missions
Accept: application/json

###

POST {{AarhusSpaceProgram.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userName": "{{ManagerUserName}}",
  "password": "{{ManagerPassword}}"
}

###

GET {{AarhusSpaceProgram.Api_HostAddress}}/api/experiments
Authorization: Bearer {{token}}
Accept: application/json

###

POST {{AarhusSpaceProgram.Api_HostAddress}}/api/experiments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Radiation Shielding Study",
  "description": "Measures shielding performance during the mission.",
  "missionId": 1,
  "scientistId": 1
}

###

GET {{AarhusSpaceProgram.Api_HostAddress}}/api/missions?status=Active
Accept: application/json

###

GET {{AarhusSpaceProgram.Api_HostAddress}}/api/missions/1/logs
Authorization: Bearer {{token}}
Accept: application/json

###

POST {{AarhusSpaceProgram.Api_HostAddress}}/api/missions/1/logs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message": "Telemetry check completed",
  "timestamp": "2026-05-05T12:00:00Z"
}

###
